# ============================================================
#   Organizador Pro — Configuracao de Producao Portavel
#   Copie este arquivo como .env na pasta interface_laravel/
#   e ajuste as variaveis marcadas com [CONFIGURAR]
# ============================================================

APP_NAME="Organizador Pro"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---- Banco de Dados ----------------------------------------
# IMPORTANTE: O caminho do SQLite sera resolvido de forma
# relativa pelo motor Python. O Laravel usa o caminho absoluto
# configurado abaixo. Atualize para o caminho real no volume.
# [CONFIGURAR] Substitua pelo caminho absoluto no volume de destino.
DB_CONNECTION=sqlite
DB_DATABASE=
DB_FOREIGN_KEYS=true
DB_TIMEOUT=30

# ---- Sessao / Cache / Fila ---------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ---- Mail (desabilitado em producao) -----------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="organizadorpro@local"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Configuracoes do Motor Python -------------------------
# [CONFIGURAR] Caminho absoluto para a pasta destino dos arquivos organizados.
DESTINATION_PATH=

# [CONFIGURAR] Provedor de embeddings: "local" (sem custo) ou "gemini"
EMBEDDING_PROVIDER=local

# [CONFIGURAR] Chave da API Gemini (obrigatoria para classificacao semantica via LLM)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# [CONFIGURAR] Provedor de LLM: "gemini" (recomendado) ou "mock" (para testes)
LLM_PROVIDER=gemini

# ---- AWS (nao utilizado — mantido por compatibilidade) -----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
